# ════════════════════════════════════════════════════════════
# ARIA MUSIC SCHOOL — Environment Variables
# Copy this file to .env and fill in real values for local dev.
# In Railway, set these in the project Variables tab.
# ════════════════════════════════════════════════════════════

# PostgreSQL connection — Railway provides this automatically as DATABASE_URL
DATABASE_URL=postgresql://user:password@host:port/database

# JWT secret for signing auth tokens — generate a long random string
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Default admin password used by seed script (CHANGE after first login)
ADMIN_DEFAULT_PASSWORD=ChangeMe123!

# CORS — comma-separated list of allowed origins, or * for any
CORS_ORIGIN=*

# Optional — port (Railway sets PORT automatically)
PORT=3000

# Optional — node env
NODE_ENV=development

# Optional — directory for uploaded files (use a Railway Volume in production)
UPLOAD_DIR=./uploads
